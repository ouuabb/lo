{
  "name": "@yourname/note-cli",
  "version": "1.0.0",
  "description": "命令行Markdown笔记管理工具",
  "main": "src/index.cjs",
  "bin": {
    "lo": "bin/note.cjs"
  },
  "scripts": {
    "start": "node bin/note.cjs",
    "dev": "nodemon bin/note.cjs",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/**/*.cjs",
    "format": "prettier --write src/**/*.cjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky"
  },
  "keywords": [
    "notes",
    "markdown",
    "cli",
    "knowledge-base"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "fs-extra": "^11.2.0",
    "fuse.js": "^7.0.0",
    "glob": "^10.3.10",
    "inquirer": "^9.2.19",
    "sqlite3": "^6.0.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "vitepress": "^1.6.4"
  }
}
